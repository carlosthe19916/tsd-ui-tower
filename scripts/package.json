{
  "name": "@tsd-ui-tower/scripts",
  "description": "Data pipeline scripts for PR monitoring",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "module": "./dist/index.mjs",
  "bin": {
    "review-rot": "./dist/cli.mjs"
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "clean:all": "rimraf ./dist ./node_modules",
    "lint": "eslint --max-warnings 0 .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check --ignore-path ../.prettierignore './src/**/*.{ts,js,json}'",
    "format:fix": "prettier --write --ignore-path ../.prettierignore './src/**/*.{ts,js,json}'",
    "prebuild": "npm run clean",
    "build": "cross-env NODE_ENV=production rollup -c"
  },
  "dependencies": {
    "@octokit/graphql": "^9.0.3",
    "yaml": "^2.8.0"
  }
}
